{
  "manifest_version": 3,
  "name": "GetMarks Auto-Timer",
  "version": "1.0",
  "description": "Automatically waits on a question and reveals the solution.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://web.getmarks.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.getmarks.app/*"
      ],
      "js": [
        "content/content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}